<?xml version="1.0" encoding="utf-8"?>
<!-- Action-bar toggle: outlined pill with an icon + label, so it reads clearly
     as a button and says what it does. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/toggle_button_bg"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="10dp"
    android:paddingEnd="14dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <ImageView
        android:id="@+id/toggle_icon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_play_green"
        android:contentDescription="@string/start_service" />

    <TextView
        android:id="@+id/toggle_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:text="@string/start_service"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="13sp" />
</LinearLayout>
