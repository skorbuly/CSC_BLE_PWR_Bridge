<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/card_margin"
    card_view:cardBackgroundColor="@color/cardBackground"
    card_view:cardCornerRadius="10dp"
    card_view:cardElevation="2dp">

    <LinearLayout
        android:id="@+id/ant_device_background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_default_padding">

        <!-- Header: name + type/state on the left, broadcast control on the right -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/ant_device_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_device_name"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:text="@string/example_device_id" />

                <TextView
                    android:id="@+id/ant_device_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_device_type"
                    android:textColor="@color/textSecondary"
                    android:text="@string/example_ant_hr" />
            </LinearLayout>

            <idv.markkuo.cscblebridge.antrecyclerview.BroadcastButtonView
                android:id="@+id/broadcast_button_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Primary live data -->
        <TextView
            android:id="@+id/ant_device_data"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textSize="@dimen/text_device_data"
            android:textStyle="bold"
            android:textColor="@color/textAccent"
            android:text="@string/example_80_bpm" />

        <!-- Detail block (manufacturer, model, firmware, ids, battery, signal…) -->
        <TextView
            android:id="@+id/ant_device_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="@dimen/text_device_detail"
            android:textColor="@color/textSecondary"
            android:lineSpacingExtra="3dp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
